# ═══════════════════════════════════════════════════════════════════════════
#  keys_user.config  —  Vim/Neovim-style keybindings for sioyek
#
#  Reference: /etc/sioyek/keys.config
#  Docs:      https://sioyek-documentation.readthedocs.io/
#
#  Design principles:
#    • h/j/k/l  → scroll / pan (like Vim cursor movement)
#    • Ctrl-d/u → half-page scroll (mirrors Neovim <C-d>/<C-u>)
#    • Ctrl-f/b → full-page scroll (mirrors Vim <C-f>/<C-b>)
#    • Everything not overridden stays at its sioyek default.
# ═══════════════════════════════════════════════════════════════════════════

# ── Navigation (Vim hjkl) ──────────────────────────────────────────────────
move_down                           j
move_up                             k
move_left                           h
move_right                          l

screen_down                         <C-d>
screen_up                           <C-u>

next_page                           <C-f>
previous_page                       <C-b>

# Arrow keys mirror hjkl (vim-adjacent)
move_down                           <C-down>
move_up                             <C-up>
move_left                           <left>
move_right                          <right>

# ── Zoom / Sizing (vim-adjacent: = to zoom in, - to zoom out, 0 to reset to fit) ──
#   (default sioyek has + for zoom_in, = for fit_to_page_width, - for zoom_out)
#   Here we make = the primary zoom-in so no shift is needed, and use 0 for fit.
zoom_in                             =
zoom_out                            -
zoom_in                             +            # keep shift+= as backup
fit_to_page_width                   0            # reset to fit (like many apps)
fit_to_page_width_smart             z=
fit_to_page_height                  z0
fit_to_page_height_smart            zO

# ── Visual mark (rebound from default j/k since those are now scroll) ──────
move_visual_mark_down               <down>
move_visual_mark_up                 <up>
move_visual_mark_down               <C-j>
move_visual_mark_up                 <C-k>

# ── Search (Vim-style: / for search, n/N for next/prev) ────────────────────
search                              ?
search                              /

# ── Goto definition (like Neovim gd from lsp.lua) ─────────────────────────
goto_definition                     gd

# ── Chapter navigation (like Vim ]c / [c) ─────────────────────────────────
next_chapter                        ]c
prev_chapter                        [c

# ── Overview definition (like Vim g]) ─────────────────────────────────────
#   overview_definition is like a pop-up peek at the definition under cursor
overview_definition                 g]

# ── Portal navigation (keep vim-adjacent) ─────────────────────────────────
portal_to_definition                ]
portal                              p
delete_portal                       dp
edit_portal                         P

# ── Misc vim-like enhancements ────────────────────────────────────────────
# Open recently used documents (like Vim <C-o> for jumplist back)
open_prev_doc                       <C-o>
open_last_document                  <C-S-o>

# Better quit (like Vim :q)
quit                                q
